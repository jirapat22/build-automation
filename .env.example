# ── JIRA (Atlassian Cloud) ─────────────────────────────────────────────────
# Full URL of your Atlassian Cloud instance (no trailing slash)
JIRA_BASE_URL=https://your-domain.atlassian.net

# Email address you use to log in to JIRA
JIRA_EMAIL=you@example.com

# API token generated at https://id.atlassian.net/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# The short key of your JIRA project (visible in issue keys, e.g. "HW" in HW-123)
JIRA_PROJECT_KEY=HW

# Sub-task issue type name in your project (usually "Subtask" or "Sub-task")
JIRA_SUBTASK_TYPE=Subtask


# ── Google Drive ───────────────────────────────────────────────────────────
# ID of the root Drive folder where all serial-number folders will be created
# Get from the folder URL: drive.google.com/drive/folders/<FOLDER_ID>
GDRIVE_ROOT_FOLDER_ID=your_root_folder_id_here

# File ID of the Google Sheets template to copy for each unit
# Get from the file URL: docs.google.com/spreadsheets/d/<FILE_ID>/edit
SHEETS_TEMPLATE_FILE_ID=your_sheets_template_id_here

# File ID of the Google Docs template to copy for each unit
# Get from the file URL: docs.google.com/document/d/<FILE_ID>/edit
DOCS_TEMPLATE_FILE_ID=your_docs_template_id_here
